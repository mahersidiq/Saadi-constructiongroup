---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import AreaHero from '@/components/sections/service-areas/AreaHero.astro';
import AreaServices from '@/components/sections/service-areas/AreaServices.astro';
import NearbyAreas from '@/components/sections/service-areas/NearbyAreas.astro';
import CTABanner from '@/components/sections/home/CTABanner.astro';
import { serviceAreas } from '@/data/serviceAreas';

export function getStaticPaths() {
  return serviceAreas.map((area) => ({
    params: { slug: area.slug },
  }));
}

const { slug } = Astro.params;
const area = serviceAreas.find((a) => a.slug === slug);
if (!area) return Astro.redirect('/404');

let nearbyAreas = [];
if (area.nearbyAreas && area.nearbyAreas.length > 0) {
  nearbyAreas = area.nearbyAreas
    .map((s) => serviceAreas.find((a) => a.slug === s))
    .filter(Boolean);
} else {
  nearbyAreas = serviceAreas.filter((a) => a.slug !== slug).slice(0, 5);
}

const canonical = `https://www.saadiconstructiongroup.com/service-areas/${area.slug}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  name: 'Saadi Construction Group',
  description: area.metaDescription || `Custom home builder serving ${area.name}, TX.`,
  url: canonical,
  telephone: '(832) 205-8178',
  email: 'info@saadiconstructiongroup.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '801 Travis St Suite 2101',
    addressLocality: 'Houston',
    addressRegion: 'TX',
    postalCode: '77002',
    addressCountry: 'US',
  },
  areaServed: { '@type': 'City', name: area.name, containedInPlace: { '@type': 'State', name: 'Texas' } },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.saadiconstructiongroup.com' },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://www.saadiconstructiongroup.com/service-areas' },
    { '@type': 'ListItem', position: 3, name: area.name, item: canonical },
  ],
};

const jsonLd = [localBusinessSchema, breadcrumbSchema];
---

<Layout
  title={area.metaTitle || `Custom Home Builder ${area.name} TX | Saadi Construction Group`}
  description={area.metaDescription || `Custom home builder serving ${area.name}, Texas. Plans, engineering, permits, and full custom home construction under one contract.`}
  keywords={`custom home builder ${area.name}, ${area.name} TX home construction, design-build ${area.name}`}
  canonicalUrl={canonical}
  jsonLd={jsonLd}
>
  <AreaHero name={area.name} county={area.county} headline={`Custom Home Builder in ${area.name} TX`} />
  {area.localContent && (
    <section class="bg-white py-12">
      <div class="container-main px-4 max-w-3xl">
        <p class="text-lg text-gray-700 leading-relaxed">{area.localContent}</p>
      </div>
    </section>
  )}
  <AreaServices name={area.name} />
  <NearbyAreas nearbyAreas={nearbyAreas} />
  <CTABanner />
</Layout>

---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Saadi Construction Group"
  description="The page you are looking for does not exist. Return to the Saadi Construction Group homepage."
  noindex={true}
>
  <section class="min-h-[80vh] flex items-center justify-center bg-navy relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(201,149,42,0.06),transparent_70%)]"></div>
    <div class="relative z-10 text-center px-4 py-20">
      <span class="animate-fade-in-up inline-block text-8xl md:text-9xl font-extrabold font-heading text-gold/20">404</span>
      <h1 class="animate-fade-in-up-delay font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mt-4">Page Not Found</h1>
      <p class="animate-fade-in-up-delay-2 mt-4 text-lg text-gray-300 max-w-md mx-auto">The page you are looking for does not exist or has been moved.</p>
      <div class="animate-fade-in-up-delay-2 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="btn-primary text-lg px-8 py-4">Back to Home</a>
        <a href="/contact" class="inline-block rounded-lg border-2 border-white/20 px-8 py-4 text-lg font-semibold text-white hover:border-gold hover:text-gold transition-colors">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>

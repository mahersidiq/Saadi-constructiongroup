---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';

const values = [
  {
    title: 'Transparency',
    description: 'Detailed scopes, fixed-price contracts, and weekly project updates. You always know exactly where your project stands and what it will cost.',
  },
  {
    title: 'Accountability',
    description: 'One contract covers everything — plans, permits, and construction. If something needs to be resolved, you call one number. There is no gap between the design team and the build team because they are the same team.',
  },
  {
    title: 'Built for Houston',
    description: "We work exclusively in the Greater Houston metro and understand its permitting processes, soil conditions, flood zone requirements, and climate demands better than out-of-market contractors.",
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'GeneralContractor',
    name: 'Saadi Construction Group',
    url: 'https://www.saadiconstructiongroup.com',
    telephone: '(832) 205-8178',
    email: 'info@saadiconstructiongroup.com',
    description: 'Houston-based custom home builder handling plans, engineering, permits, and construction under one contract.',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '801 Travis St Suite 2101',
      addressLocality: 'Houston',
      addressRegion: 'TX',
      postalCode: '77002',
      addressCountry: 'US',
    },
    areaServed: { '@type': 'City', name: 'Houston', containedInPlace: { '@type': 'State', name: 'Texas' } },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.saadiconstructiongroup.com' },
      { '@type': 'ListItem', position: 2, name: 'About', item: 'https://www.saadiconstructiongroup.com/about' },
    ],
  },
];
---

<Layout
  title="About Saadi Construction Group | Houston Custom Home Builder"
  description="Saadi Construction Group is a Houston-based custom home builder handling plans, engineering, permits, and construction under one contract. Owner-led on every project."
  keywords="about Saadi Construction Group, Houston custom home builder, design-build contractor Houston"
  canonicalUrl="https://www.saadiconstructiongroup.com/about"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center bg-gradient-to-br from-navy via-[#14304d] to-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.08),transparent_60%)]"></div>
    <div class="relative z-10 container-main px-4 py-20 md:py-28 text-center">
      <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
        One-Stop Custom Home Builder. Owner on Every Project.
      </h1>
      <p class="animate-fade-in-up-delay mt-6 text-lg md:text-xl text-gray-300 max-w-2xl mx-auto">
        A Houston-based general contracting firm that handles everything — from blank lot to move-in ready.
      </p>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="section-padding bg-white">
    <div class="container-main px-4 max-w-4xl">
      <div class="animate-on-scroll">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal mb-6">Who We Are</h2>
        <p class="text-lg text-gray-700 leading-relaxed">
          Saadi Construction Group is a licensed Houston general contracting firm built around a simple idea: homeowners should not have to manage an architect, a structural engineer, a permit runner, and a general contractor separately. We handle all of it. Architectural plans, structural engineering, city permitting, and full construction are managed under one contract by one accountable team — with the owner on every project from the first call to the final walkthrough.
        </p>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="section-padding bg-light-gray">
    <div class="container-main px-4 max-w-4xl">
      <div class="animate-on-scroll">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal mb-6">What Makes Us Different</h2>
        <p class="text-lg text-gray-700 leading-relaxed">
          Most general contractors build to a set of plans someone else produced. We produce the plans. Our process starts with your vision, moves through design and engineering we coordinate directly, runs through city permit submission we manage, and ends with a finished home built by our licensed team and Houston subcontractor network. You never chase a separate vendor or wonder where your project stands.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="section-padding bg-white">
    <div class="container-main px-4 max-w-5xl">
      <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-charcoal mb-12 text-center">Our Approach</h2>
      <div class="grid gap-8 md:grid-cols-3">
        {values.map((value) => (
          <div class="animate-on-scroll rounded-xl bg-light-gray p-8 border border-gray-200">
            <h3 class="font-heading text-xl font-bold text-navy mb-3">{value.title}</h3>
            <p class="text-gray-700 leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="section-padding bg-light-gray">
    <div class="container-main px-4 max-w-4xl">
      <div class="animate-on-scroll">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal mb-6">Service Area</h2>
        <p class="text-lg text-gray-700 leading-relaxed">
          We serve the Greater Houston metropolitan area including Katy, Sugar Land, Pearland, Pasadena, The Woodlands, Spring, Cypress, League City, Missouri City, Conroe, Baytown, Richmond, Friendswood, and Humble across Harris, Fort Bend, Montgomery, Brazoria, and Galveston Counties.
        </p>
      </div>
    </div>
  </section>

  <!-- Footer Statement -->
  <section class="bg-navy py-12">
    <div class="container-main px-4 text-center">
      <p class="animate-on-scroll text-lg font-semibold text-gold tracking-wide">
        General Contractor | Licensed &amp; Insured | Houston, Texas
      </p>
    </div>
  </section>
</Layout>

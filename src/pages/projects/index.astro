---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import ProjectsFilter from '@/islands/ProjectsFilter.jsx';

const projects = [
  {
    slug: 'custom-home-katy-1',
    title: 'Custom Home Build',
    location: 'Katy, TX',
    size: '3,200 sq ft',
    scope_type: 'Custom Home',
    description: 'Ground-up custom home on a one-acre lot. Full design-build scope including architectural plans, structural engineering, Fort Bend County permits, and complete construction.',
  },
  {
    slug: 'design-build-sugar-land-1',
    title: 'Design-Build Custom Home',
    location: 'Sugar Land, TX',
    size: '4,100 sq ft',
    scope_type: 'Design-Build',
    description: 'Full design-build engagement — architectural plans, structural engineering, city permits, and high-specification construction delivered under one fixed-price contract.',
  },
  {
    slug: 'home-addition-the-woodlands-1',
    title: 'Two-Story Home Addition',
    location: 'The Woodlands, TX',
    size: '900 sq ft',
    scope_type: 'Addition',
    description: 'Second-story addition over an existing single-story home. Structural engineering for tie-in to existing foundation and framing, Montgomery County permits, and full construction.',
  },
  {
    slug: 'luxury-home-missouri-city-1',
    title: 'Luxury Custom Home',
    location: 'Missouri City, TX',
    size: '5,400 sq ft',
    scope_type: 'Luxury',
    description: 'High-specification luxury home with custom millwork, designer finishes, and engineered foundation for Fort Bend soil conditions. Full plan-to-finish under one contract.',
  },
  {
    slug: 'new-home-cypress-1',
    title: 'New Home Construction',
    location: 'Cypress, TX',
    size: '2,800 sq ft',
    scope_type: 'New Construction',
    description: 'Ground-up new home build on a Harris County lot. Site evaluation, plans, permits, foundation, framing, MEP, and finishes managed under one contract.',
  },
  {
    slug: 'plans-permits-pearland-1',
    title: 'Plans, Permits & Engineering',
    location: 'Pearland, TX',
    size: '2,400 sq ft',
    scope_type: 'Plans & Permits',
    description: 'Standalone plans, permits, and engineering engagement. Architectural drawings, structural engineering, soil report review, and Brazoria County permit submission.',
  },
];
---

<Layout
  title="Custom Home Projects | Saadi Construction Group | Houston, TX"
  description="Recent custom home builds, additions, and design-build projects from Saadi Construction Group across the Greater Houston metro."
  keywords="custom home projects Houston, custom home builder portfolio Houston TX, design-build projects Houston"
  canonicalUrl="https://www.saadiconstructiongroup.com/projects"
>
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center bg-gradient-to-br from-navy via-[#14304d] to-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.08),transparent_60%)]"></div>
    <div class="relative z-10 container-main px-4 py-20 md:py-28 text-center">
      <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
        Custom Home Projects — Houston and Surrounding Areas
      </h1>
      <p class="animate-fade-in-up-delay mt-6 text-lg md:text-xl text-gray-300 max-w-2xl mx-auto">
        A look at the kinds of custom homes, additions, and design-build projects we deliver across the Greater Houston metro.
      </p>
    </div>
  </section>

  <!-- Filter + Grid -->
  <section class="section-padding bg-white">
    <div class="container-main">
      <ProjectsFilter client:load projects={projects} />
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-navy overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gold"></div>
    <div class="section-padding">
      <div class="container-main text-center">
        <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-white">Planning a Similar Build?</h2>
        <p class="animate-on-scroll mt-4 text-lg text-gray-300 max-w-xl mx-auto">Tell us about your lot or project and we'll provide a detailed fixed-price quote within 5 business days.</p>
        <div class="animate-on-scroll mt-8">
          <a href="/contact" class="btn-primary text-lg px-8 py-4">Request a Quote</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

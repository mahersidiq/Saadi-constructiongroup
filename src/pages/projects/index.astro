---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import ProjectsFilter from '@/islands/ProjectsFilter.jsx';

const projects = [
  { slug: 'example-project-1', apt_name: 'Residences at Almeda', title: 'Garden-Style Community Renovation', location: 'Houston, TX', unit_count: 240, scope_type: 'Gut Rehab', image_url: '/images/saadi-kitchen-renovation-houston-1.jpg' },
  { slug: 'example-project-2', apt_name: 'The Mason at Katy', title: 'Mid-Rise Value-Add Program', location: 'Katy, TX', unit_count: 180, scope_type: 'Interior', image_url: '/images/saadi-apartment-living-room-houston-1.jpg' },
  { slug: 'example-project-3', apt_name: 'Parkview Commons', title: 'Suburban Apartment Rehab', location: 'Sugar Land, TX', unit_count: 120, scope_type: 'Interior', image_url: '/images/saadi-bathroom-double-vanity-houston-1.jpg' },
  { slug: 'example-project-4', apt_name: 'The Grand at Woodlands', title: 'Clubhouse & Amenity Renovation', location: 'The Woodlands, TX', unit_count: 300, scope_type: 'Common Areas', image_url: '/images/saadi-clubhouse-renovation-houston-1.jpg' },
  { slug: 'example-project-5', apt_name: 'Bayou Crossing', title: 'Exterior & Curb Appeal Overhaul', location: 'Pearland, TX', unit_count: 200, scope_type: 'Exterior', image_url: '/images/saadi-apartment-exterior-houston-1.jpg' },
  { slug: 'example-project-6', apt_name: 'Spring Gate', title: 'Common Area Modernization', location: 'Spring, TX', unit_count: 160, scope_type: 'Common Areas', image_url: '/images/saadi-amenity-renovation-houston-1.jpg' },
];
---

<Layout
  title="Apartment Renovation Projects | Saadi Construction Group | Houston, TX"
  description="View our portfolio of apartment renovation projects across Houston and surrounding areas. Full gut rehabs, value-add programs, and property-wide renovations."
  keywords="apartment renovation projects Houston, multifamily renovation portfolio, apartment rehab before after"
  canonicalUrl="https://saadiconstructiongroup.com/projects"
>
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center bg-gradient-to-br from-navy via-[#14304d] to-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.08),transparent_60%)]"></div>
    <div class="relative z-10 container-main px-4 py-20 md:py-28 text-center">
      <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
        Apartment Renovation Projects — Houston and Surrounding Areas
      </h1>
      <p class="animate-fade-in-up-delay mt-6 text-lg md:text-xl text-gray-300 max-w-2xl mx-auto">
        Apartment renovation work across Houston and surrounding communities.
      </p>
    </div>
  </section>

  <!-- Filter + Grid -->
  <section class="section-padding bg-white">
    <div class="container-main">
      <ProjectsFilter client:load projects={projects} />
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-navy overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gold"></div>
    <div class="section-padding">
      <div class="container-main text-center">
        <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-white">Planning a Similar Renovation?</h2>
        <p class="animate-on-scroll mt-4 text-lg text-gray-300 max-w-xl mx-auto">Tell us about your property and we'll provide a detailed scope and estimate.</p>
        <div class="animate-on-scroll mt-8">
          <a href="/contact" class="btn-primary text-lg px-8 py-4">Request a Bid</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

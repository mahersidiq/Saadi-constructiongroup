---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import { allServices } from '@/data/services';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Custom Home Builder Services',
    description: 'Custom home builder services offered by Saadi Construction Group in Houston, TX — design-build, plans, permits, and construction.',
    itemListElement: allServices.map((service, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: service.name,
      url: `https://www.saadiconstructiongroup.com/services/${service.slug}`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.saadiconstructiongroup.com' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://www.saadiconstructiongroup.com/services' },
    ],
  },
];

const icons = {
  'custom-home-design-build': `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`,
  'luxury-custom-homes': `<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />`,
  'new-home-construction': `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />`,
  'home-additions-expansions': `<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />`,
  'plans-permits-engineering': `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25" />`,
  'construction-management': `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
};
---

<Layout
  title="Custom Home Builder Services Houston TX | Saadi Construction Group"
  description="Saadi Construction Group offers custom home design-build, new home construction, luxury homes, additions, plans, permits, and engineering in Houston TX — one contract, one team."
  keywords="custom home builder services Houston, design-build Houston, new home construction Houston TX"
  canonicalUrl="https://www.saadiconstructiongroup.com/services"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center bg-gradient-to-br from-navy via-[#14304d] to-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.08),transparent_60%)]"></div>
    <div class="relative z-10 container-main px-4 py-20 md:py-28 text-center">
      <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
        Custom Home Builder Services in Houston TX
      </h1>
      <p class="animate-fade-in-up-delay mt-6 text-lg md:text-xl text-gray-300 max-w-2xl mx-auto">
        From architectural plans and structural engineering through city permits and full construction — we handle the entire process under one contract.
      </p>
    </div>
  </section>

  <!-- Service Cards Grid -->
  <section class="section-padding bg-white">
    <div class="container-main">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {allServices.map((service) => (
          <a
            href={`/services/${service.slug}`}
            class="animate-on-scroll group flex flex-col rounded-2xl border border-gray-200 p-7 hover:border-gold hover:shadow-lg transition-all duration-200"
          >
            <span class="inline-block self-start mb-4 px-3 py-1 text-xs font-semibold uppercase tracking-wide rounded-full bg-gold/10 text-gold border border-gold/20">
              {service.category}
            </span>
            <svg class="w-7 h-7 text-gold mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icons[service.slug]} />
            <h2 class="font-heading text-xl font-bold text-charcoal group-hover:text-navy transition-colors mb-3">
              {service.name}
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed flex-1">
              {service.description}
            </p>
            <span class="mt-5 text-sm font-semibold text-gold group-hover:underline">
              Learn more →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-navy overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gold"></div>
    <div class="section-padding">
      <div class="container-main text-center">
        <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-white">Not Sure Which Service You Need?</h2>
        <p class="animate-on-scroll mt-4 text-lg text-gray-300 max-w-xl mx-auto">Tell us about your project and we'll recommend the right scope of work.</p>
        <div class="animate-on-scroll mt-8">
          <a href="/contact" class="btn-primary text-lg px-8 py-4">Request a Quote</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

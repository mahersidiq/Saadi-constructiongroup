---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/sections/home/Hero.astro';
import TrustBar from '@/components/sections/home/TrustBar.astro';
import StatsBar from '@/components/sections/home/StatsBar.astro';
import OneStopCallout from '@/components/sections/home/OneStopCallout.astro';
import ServicesGrid from '@/components/sections/home/ServicesGrid.astro';
import WhySaadi from '@/components/sections/home/WhySaadi.astro';
import FeaturedProjects from '@/components/sections/home/FeaturedProjects.astro';
import Process from '@/components/sections/home/Process.astro';
import ServiceAreas from '@/components/sections/home/ServiceAreas.astro';
import FAQ from '@/components/sections/home/FAQ.astro';
import CTABanner from '@/components/sections/home/CTABanner.astro';

const homeFaqs = [
  {
    question: 'Do you handle plans and permits or do I need to hire someone separately?',
    answer: 'We handle everything. Saadi Construction Group manages architectural plans, structural engineering, and city permit submission in-house as part of our service. You do not need to hire a separate architect, engineer, or permit expediter. One contract covers the full process from design through construction.',
  },
  {
    question: 'How much does it cost to build a custom home in Houston TX?',
    answer: 'Custom home construction in Greater Houston typically ranges from $150 to $350 per square foot depending on finish level, site conditions, and design complexity. A 2,500 sq ft home at mid-range finishes generally runs $375,000–$550,000 in hard construction costs, excluding land. Saadi Construction Group provides a detailed fixed-price quote within 5 business days of a site visit.',
  },
  {
    question: 'How long does it take to build a custom home in Houston?',
    answer: 'A standard custom home in Houston takes 10–14 months from signed contract to final walkthrough. This includes plan production (6–10 weeks), city permit approval (8–14 weeks depending on municipality), and construction (6–9 months depending on size and scope). We provide a detailed project schedule before construction begins.',
  },
  {
    question: 'What areas do you build in?',
    answer: 'We build throughout the Greater Houston metropolitan area including Houston, Katy, Sugar Land, Pearland, The Woodlands, Spring, Cypress, League City, Missouri City, Conroe, Baytown, Richmond, Friendswood, Humble, and Pasadena — covering Harris, Fort Bend, Montgomery, Brazoria, and Galveston Counties.',
  },
  {
    question: 'Do you build on my lot or do you provide lots?',
    answer: 'We build on your lot. If you need help evaluating a lot, we advise on site suitability, flood zone status, utility availability, and setback requirements during the consultation.',
  },
  {
    question: 'What is a design-build contract and why does it matter?',
    answer: 'A design-build contract means one company is responsible for both designing and building your home. This eliminates the gap between what an architect draws and what a contractor can build for your budget — because both phases are managed by the same team. One contract, one contact, one accountable party.',
  },
];

const generalContractorSchema = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  name: 'Saadi Construction Group',
  description: 'Houston custom home builder offering plans, engineering, permits, and full construction under one contract.',
  url: 'https://www.saadiconstructiongroup.com',
  telephone: '+18322058178',
  email: 'info@saadi-construction.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '801 Travis St Suite 2101',
    addressLocality: 'Houston',
    addressRegion: 'TX',
    postalCode: '77002',
    addressCountry: 'US',
  },
  areaServed: [
    'Houston', 'Katy', 'Sugar Land', 'Pearland', 'The Woodlands',
    'Spring', 'Cypress', 'League City', 'Missouri City', 'Conroe',
    'Baytown', 'Richmond', 'Friendswood', 'Humble', 'Pasadena',
  ],
  serviceType: [
    'Custom Home Design-Build',
    'Luxury Custom Home Construction',
    'New Home Construction',
    'Home Additions and Expansions',
    'Residential Plans Permits and Engineering',
    'Construction Management',
  ],
  priceRange: '$$$$',
  openingHours: 'Mo-Fr 07:00-18:00',
};

const faqPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: "Houston Custom Home Builder | Saadi Construction Group",
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', '.hero-description', '.section-heading'],
  },
  url: 'https://www.saadiconstructiongroup.com',
};

const jsonLd = [generalContractorSchema, faqPageSchema, speakableSchema];

const pageTitle = "Houston Custom Home Builder | Plans, Permits & Construction | Saadi Construction Group";
const pageDescription = "Saadi Construction Group is Houston's one-stop custom home builder. We handle plans, engineering, permits, and full construction under one contract — owner-led from first call to final walkthrough. Request a quote in 5 business days.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords="custom home builder Houston, Houston custom homes, design-build Houston, new home construction Houston TX"
  canonicalUrl="https://www.saadiconstructiongroup.com"
  jsonLd={jsonLd}
>
  <Hero />
  <TrustBar />
  <StatsBar />
  <OneStopCallout />
  <ServicesGrid />
  <WhySaadi />
  <FeaturedProjects />
  <Process />
  <FAQ faqs={homeFaqs} />
  <ServiceAreas />
  <CTABanner />
</Layout>

---
const { title, subheadline, category } = Astro.props;
---

<section class="relative min-h-[60vh] flex items-center bg-gradient-to-br from-navy via-[#14304d] to-charcoal overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.1),transparent_60%)]"></div>
  <div class="relative z-10 container-main px-4 py-20 md:py-28">
    {category && (
      <span class="animate-fade-in-up inline-block mb-4 px-4 py-1.5 text-sm font-semibold tracking-wide uppercase rounded-full bg-gold/15 text-gold border border-gold/30">
        {category}
      </span>
    )}
    <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight max-w-3xl">
      {title}
    </h1>
    {subheadline && (
      <p class="animate-fade-in-up-delay mt-6 text-lg md:text-xl text-gray-300 max-w-2xl leading-relaxed">
        {subheadline}
      </p>
    )}
    <div class="animate-fade-in-up-delay-2 mt-10">
      <a href="/contact" class="btn-primary inline-block text-lg px-8 py-4">Request a Bid</a>
    </div>
  </div>
</section>

---
const { includes, whatIsIt, bestFor } = Astro.props;
---

<section class="py-16 md:py-24 bg-light-gray">
  <div class="container-main px-4">
    {whatIsIt && (
      <div class="animate-on-scroll mb-14 max-w-3xl">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal mb-6">What Is It</h2>
        <p class="text-lg text-gray-700 leading-relaxed">{whatIsIt}</p>
      </div>
    )}

    {includes && includes.length > 0 && (
      <div class="animate-on-scroll mb-14 max-w-3xl">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal mb-6">What's Included</h2>
        <ul class="grid gap-3 sm:grid-cols-2">
          {includes.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-gray-700">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {bestFor && (
      <div class="animate-on-scroll max-w-3xl rounded-lg bg-white p-6 md:p-8 border-l-4 border-gold shadow-sm">
        <h3 class="font-heading text-xl font-bold text-charcoal mb-3">Best For</h3>
        <p class="text-gray-700 leading-relaxed">{bestFor}</p>
      </div>
    )}
  </div>
</section>

---
const values = [
  {
    title: 'Multifamily-Only Focus',
    text: 'Every project we take is an apartment community. That specialization shows in our execution.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />`,
  },
  {
    title: 'Proven at Scale',
    text: 'Our team has delivered construction programs across 1,000+ multifamily units in Houston — from ground-up developments to full gut rehab programs.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />`,
  },
  {
    title: 'Owner on Every Project',
    text: 'You work directly with decision-making leadership from bid to punchlist. No handoffs.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />`,
  },
  {
    title: 'Houston Subcontractor Network',
    text: "Deep relationships with Houston's best trade contractors across every discipline — built over years of multifamily work.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />`,
  },
];
---

<section class="section-padding bg-light-gray">
  <div class="container-main">
    <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-charcoal text-center">
      Why Apartment Owners Choose Saadi
    </h2>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map((item) => (
        <div class="animate-on-scroll bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 rounded-lg bg-navy/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={item.icon} />
          </div>
          <h3 class="font-heading text-lg font-bold text-charcoal mb-2">{item.title}</h3>
          <p class="text-sm text-gray-600 leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

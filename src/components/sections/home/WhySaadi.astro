---
const values = [
  {
    title: 'Truly One-Stop',
    text: 'Plans, engineering, permits, and construction — all under one contract. You never chase down a separate architect, engineer, or permit runner.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
  {
    title: 'Owner on Every Project',
    text: "You work directly with the owner from first call to final walkthrough. No handoffs to a project manager you've never met.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />`,
  },
  {
    title: 'Fixed-Price Contracts',
    text: 'We scope your project completely before we start. Your contract price is your build price — no surprise change orders mid-construction.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 8.25H7.5a2.25 2.25 0 00-2.25 2.25v9a2.25 2.25 0 002.25 2.25h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25H15M9 12l2 2 4-4m-3-7v6.75M12 3l3 3m-3-3L9 6" />`,
  },
  {
    title: 'Built for Houston',
    text: "Every home is designed and built for Houston's climate, soil conditions, flood zone requirements, and city permitting process.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />`,
  },
];
---

<section class="section-padding bg-light-gray">
  <div class="container-main">
    <h2 class="animate-on-scroll section-heading font-heading text-3xl md:text-4xl font-bold text-charcoal text-center">
      Why Houston Homeowners Choose Saadi
    </h2>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map((item) => (
        <div class="animate-on-scroll bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 rounded-lg bg-navy/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={item.icon} />
          </div>
          <h3 class="font-heading text-lg font-bold text-charcoal mb-2">{item.title}</h3>
          <p class="text-sm text-gray-600 leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

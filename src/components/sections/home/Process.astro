---
const steps = [
  {
    title: 'Consultation & Quote',
    text: 'Site visit, design discussion, and a detailed fixed-price quote within 5 business days.',
  },
  {
    title: 'Plans, Engineering & Permits',
    text: 'Our team produces architectural drawings, coordinates structural engineering, and submits for city permits — all included.',
  },
  {
    title: 'Construction',
    text: 'Weekly owner updates, milestone-based billing, and full trade management from groundbreak to close-in.',
  },
  {
    title: 'Final Walkthrough & Handoff',
    text: 'Full punch walkthrough with owner, photo documentation of every system, and warranty packet at handoff.',
  },
];
---

<section class="section-padding bg-navy">
  <div class="container-main">
    <h2 class="animate-on-scroll section-heading font-heading text-3xl md:text-4xl font-bold text-white text-center">
      How We Build Your Home
    </h2>

    <!-- Desktop: horizontal timeline -->
    <div class="hidden md:grid grid-cols-4 gap-6 mt-14 relative">
      <div class="absolute top-8 left-[12.5%] right-[12.5%] h-0.5 bg-gold/30"></div>
      {steps.map((step, i) => (
        <div class="animate-on-scroll relative flex flex-col items-center text-center">
          <div class="relative z-10 w-16 h-16 rounded-full bg-gold/20 border-2 border-gold flex items-center justify-center mb-4">
            <span class="text-gold font-heading text-lg font-bold">{i + 1}</span>
          </div>
          <span class="text-gold font-heading text-sm font-bold mb-1">Step {i + 1}</span>
          <h3 class="font-heading text-lg font-bold text-white mb-2">{step.title}</h3>
          <p class="text-sm text-gray-300 leading-relaxed">{step.text}</p>
        </div>
      ))}
    </div>

    <!-- Mobile: vertical timeline -->
    <div class="md:hidden mt-10 space-y-8 relative pl-10">
      <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gold/30"></div>
      {steps.map((step, i) => (
        <div class="animate-on-scroll relative">
          <div class="absolute -left-10 top-0 w-8 h-8 rounded-full bg-gold/20 border-2 border-gold flex items-center justify-center">
            <span class="text-gold font-heading text-xs font-bold">{i + 1}</span>
          </div>
          <span class="text-gold font-heading text-sm font-bold">Step {i + 1}</span>
          <h3 class="font-heading text-base font-bold text-white mt-1">{step.title}</h3>
          <p class="text-sm text-gray-300 mt-1 leading-relaxed">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

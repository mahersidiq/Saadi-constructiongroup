  'construction-management': `<path stroke-linecap="round" stroke-linejoin="round" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3l1.5 1.5 3-3.75" />`,
};
---

<section class="section-padding bg-white">
  <div class="container-main">
    <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-charcoal text-center">
      Full-Scope Apartment Renovation Services
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {allServices.map((service) => (
        <a
          href={`/services/${service.slug}`}
          class="animate-on-scroll group flex flex-col rounded-2xl border border-gray-200 p-7 hover:border-gold hover:shadow-lg transition-all duration-200"
        >
          <span class="inline-block self-start mb-4 px-3 py-1 text-xs font-semibold uppercase tracking-wide rounded-full bg-gold/10 text-gold border border-gold/20">
            {service.category}
          </span>
          <svg class="w-6 h-6 text-gold mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icons[service.slug]} />
          <h3 class="font-heading text-lg font-bold text-charcoal group-hover:text-navy transition-colors mb-3">
            {service.name}
          </h3>
          <p class="text-sm text-gray-600 leading-relaxed flex-1">
            {service.description}
          </p>
          <span class="mt-5 text-sm font-semibold text-gold group-hover:underline">
            Learn more →
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

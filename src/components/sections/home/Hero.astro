---
import { Image } from 'astro:assets';
import heroImage from '@/assets/images/saadi-apartment-living-room-houston-1.jpg';
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
  <Image
    src={heroImage}
    alt="Renovated apartment living room Houston TX — Saadi Construction Group"
    class="absolute inset-0 w-full h-full object-cover"
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
    format="webp"
    quality={80}
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-black/65"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.08),transparent_60%)]"></div>
  <div class="relative z-10 container-main text-center px-4">
    <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight max-w-4xl mx-auto">
      Houston's Apartment Renovation &amp; Rehab Specialists
    </h1>

    <p class="animate-fade-in-up-delay mt-6 text-lg md:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
      We deliver renovation programs that drive rent premiums, accelerate
      unit turns, and protect NOI — for apartment owners and operators who
      demand institutional-grade execution.
    </p>

    <div class="animate-fade-in-up-delay-2 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/contact" class="btn-primary text-lg px-8 py-4">Request a Bid</a>
      <a href="/services" class="btn-outline text-lg px-8 py-4">Our Services</a>
    </div>
    <p class="animate-fade-in-up-delay-2 mt-6 text-gray-400 text-sm">
      Call us directly:
      <a href="tel:8323603804" class="text-gold font-semibold hover:underline">
        (832) 360-3804
      </a>
    </p>
  </div>
</section>

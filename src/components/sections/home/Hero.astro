<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
  <img
    src="/images/p8-exterior-front.png"
    alt="Houston custom home builder — Saadi Construction Group luxury modern home"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-black/65"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.08),transparent_60%)]"></div>
  <div class="relative z-10 container-main text-center px-4">
    <h1 class="animate-fade-in-up font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight max-w-4xl mx-auto">

---
const items = [
  {
    label: 'Plans & Design',
    text: 'Architectural drawings coordinated and delivered — no separate architect to hire or manage.',
  },
  {
    label: 'Engineering & Permits',
    text: 'Structural engineering and permit submission handled in-house. We run the process.',
  },
  {
    label: 'Full Construction',
    text: 'Ground-up build executed by our licensed team and vetted Houston subcontractor network.',
  },
];
---

<section class="relative bg-charcoal overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-1 bg-gold"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(201,149,42,0.1),transparent_60%)]"></div>
  <div class="section-padding relative z-10">
    <div class="container-main px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-white">
          One Contract. Everything Included.
        </h2>
        <p class="animate-on-scroll mt-6 text-lg text-gray-300 leading-relaxed">
          Most contractors hand you a blueprint and tell you to figure out permits yourself. We don't. Saadi Construction Group manages your architectural plans, structural engineering, city permits, and full construction under a single contract — so you deal with one phone number, one schedule, and one point of accountability from start to finish.
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {items.map((item) => (
          <div class="animate-on-scroll bg-white/5 border border-white/10 rounded-2xl p-6 md:p-7">
            <h3 class="font-heading text-lg md:text-xl font-bold text-gold mb-3">{item.label}</h3>
            <p class="text-gray-300 leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

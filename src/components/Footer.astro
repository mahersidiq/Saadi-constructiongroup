---
import { serviceCategories } from '@/data/services';
import { serviceAreas } from '@/data/serviceAreas';

const unitServices = serviceCategories.find((c) => c.slug === 'unit-renovation')?.services || [];
const propertyServices = serviceCategories.find((c) => c.slug === 'property-wide')?.services || [];
const managementServices = serviceCategories.find((c) => c.slug === 'management')?.services || [];
---

<footer class="bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Column 1: Logo & Contact -->
      <div>
        <a href="/" class="inline-block mb-4">
          <span class="font-heading text-2xl font-bold tracking-tight">SAADI</span>
          <span class="font-heading text-sm font-medium tracking-wide block opacity-90">CONSTRUCTION GROUP</span>
        </a>
        <p class="text-white/70 text-sm mb-6">Houston's Apartment Renovation Specialists</p>
        <div class="space-y-3 text-sm">
          <a href="tel:8323603804" class="flex items-center gap-2 text-white/80 hover:text-gold transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            (832) 360-3804
          </a>
          <a href="mailto:info@saadi-construction.com" class="flex items-center gap-2 text-white/80 hover:text-gold transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            info@saadi-construction.com
          </a>
          <p class="flex items-start gap-2 text-white/60">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            Serving Houston and Surrounding Areas
          </p>
        </div>
      </div>

      <!-- Column 2: Unit Renovation Services -->
      <div>
        <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-gold mb-4">Unit Renovation Services</h4>
        <ul class="space-y-2">
          {unitServices.map((s) => (
            <li><a href={`/services/${s.slug}`} class="text-sm text-white/70 hover:text-white transition-colors">{s.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Property-Wide Services -->
      <div>
        <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-gold mb-4">Property-Wide Services</h4>
        <ul class="space-y-2">
          {propertyServices.map((s) => (
            <li><a href={`/services/${s.slug}`} class="text-sm text-white/70 hover:text-white transition-colors">{s.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Management + Areas + Quick Links -->
      <div class="space-y-6">
        <div>
          <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-gold mb-4">Management Services</h4>
          <ul class="space-y-2">
            {managementServices.map((s) => (
              <li><a href={`/services/${s.slug}`} class="text-sm text-white/70 hover:text-white transition-colors">{s.name}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-gold mb-4">Service Areas</h4>
          <ul class="grid grid-cols-2 gap-x-3 gap-y-1.5">
            {serviceAreas.map((area) => (
              <li><a href={`/service-areas/${area.slug}`} class="text-sm text-white/70 hover:text-white transition-colors">{area.name}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-gold mb-4">Quick Links</h4>
          <ul class="space-y-2">
            <li><a href="/about" class="text-sm text-white/70 hover:text-white transition-colors">About</a></li>
            <li><a href="/contact" class="text-sm text-white/70 hover:text-white transition-colors">Contact</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-3 text-sm text-white/50">
        <p>General Contractor | Licensed &amp; Insured | Houston, Texas | Serving Harris, Fort Bend, Montgomery, Brazoria and Galveston Counties</p>
        <p>&copy; 2026 Saadi Construction Group</p>
      </div>
    </div>
  </div>
</footer>
